{
  "Version": "2012-10-17",
  "Statement": [
    {"Effect": "Allow", "Action": "s3:*", "Resource": ["arn:aws:s3:::cicd-demo-artifacts-${ACCOUNT_ID}", "arn:aws:s3:::cicd-demo-artifacts-${ACCOUNT_ID}/*"]},
    {"Effect": "Allow", "Action": ["codebuild:BatchGetBuilds", "codebuild:StartBuild"], "Resource": "*"},
    {"Effect": "Allow", "Action": ["codedeploy:*"], "Resource": "*"},
    {"Effect": "Allow", "Action": ["codestar-connections:UseConnection"], "Resource": "*"},
    {"Effect": "Allow", "Action": ["iam:PassRole"], "Resource": "*"}
  ]
}