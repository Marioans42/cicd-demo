{
  "pipeline": {
    "name": "cicd-demo-pipeline",
    "roleArn": "arn:aws:iam::463766459869:role/cicd-demo-pipeline-role",
    "artifactStore": {"type": "S3", "location": "mario-saa-lab1-2026"},
    "stages": [
      {
        "name": "Source",
        "actions": [{
          "name": "Source",
          "actionTypeId": {"category": "Source", "owner": "AWS", "provider": "CodeStarSourceConnection", "version": "1"},
          "configuration": {
            "ConnectionArn": "arn:aws:codeconnections:eu-west-3:463766459869:connection/820a90b7-bf68-4121-b78b-202e040465db",
            "FullRepositoryId": "Marioans42/cicd-demo",
            "BranchName": "main",
            "DetectChanges": "true"
          },
          "outputArtifacts": [{"name": "SourceArtifact"}]
        }]
      },
      {
        "name": "Build",
        "actions": [{
          "name": "Build",
          "actionTypeId": {"category": "Build", "owner": "AWS", "provider": "CodeBuild", "version": "1"},
          "configuration": {"ProjectName": "cicd-demo-build"},
          "inputArtifacts": [{"name": "SourceArtifact"}],
          "outputArtifacts": [{"name": "BuildArtifact"}]
        }]
      },
      {
        "name": "Deploy",
        "actions": [{
          "name": "Deploy",
          "actionTypeId": {"category": "Deploy", "owner": "AWS", "provider": "CodeDeploy", "version": "1"},
          "configuration": {"ApplicationName": "cicd-demo-app", "DeploymentGroupName": "cicd-demo-dg"},
          "inputArtifacts": [{"name": "BuildArtifact"}]
        }]
      }
    ]
  }
}
